# Telegram Bot Token (клиентские переменные с префиксом VITE_)
VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here
VITE_TELEGRAM_CHAT_ID=your_chat_id_here

# API URL для отправки заявок (на Render.com)
VITE_API_URL=https://your-app-api.onrender.com

# io.net API Key для Kimi K2
VITE_IO_NET_API_KEY=your_io_net_api_key_here

# Groq API Key для Llama 3.1
VITE_GROQ_API_KEY=your_groq_api_key_here

# Email для отправки через SMTP (серверные переменные)
EMAIL_USER=your_email_here
EMAIL_PASSWORD=your_email_password_here

# io.net API Key (серверная переменная)
IO_NET_API_KEY=your_io_net_api_key_here

# Groq API Key (серверная переменная)
GROQ_API_KEY=your_groq_api_key_here
